{
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "js/ts.tsserver.maxMemory": 4096,
    "editor.accessibilitySupport": "off",
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/.next/**": true,
        "**/.git/**": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/.next": true
    }
}